<?xml version="1.0"?>
<ruleset name="WPVIP MCP Abilities">
	<description>WordPress coding standards for WPVIP MCP Abilities plugin.</description>

	<!-- What to scan. -->
	<file>wpvip-multisite-mcp-abilities.php</file>
	<file>wpvip-mcp-site-editor-abilities.php</file>

	<!-- Show sniff codes and progress. -->
	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<!-- PHP compatibility — matches plugin header Requires PHP: 8.0. -->
	<config name="testVersion" value="8.0-"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- WordPress Coding Standards (full). -->
	<rule ref="WordPress">
		<!-- Allow short array syntax [] instead of array(). -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
	</rule>

	<!-- WordPress VIP coding standards tweaks. -->
	<rule ref="WordPress.WP.I18n">
		<!-- No text-domain — this plugin has no user-facing strings. -->
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
	</rule>

	<!-- Allow long lines in schema arrays — breaking them up hurts readability. -->
	<rule ref="Generic.Files.LineLength">
		<properties>
			<property name="lineLimit" value="200"/>
			<property name="absoluteLineLimit" value="0"/>
		</properties>
	</rule>

	<!-- WordPress filter/action callbacks must match the hook signature even if not all params are used. -->
	<rule ref="Generic.CodeAnalysis.UnusedFunctionParameter.FoundAfterLastUsed">
		<severity>0</severity>
	</rule>

	<!-- tax_query and meta_query are required for pattern filtering — no alternative. -->
	<rule ref="WordPress.DB.SlowDBQuery.slow_db_query_tax_query">
		<severity>0</severity>
	</rule>
	<rule ref="WordPress.DB.SlowDBQuery.slow_db_query_meta_query">
		<severity>0</severity>
	</rule>

	<!-- Minimum supported WordPress version for deprecated function checks. -->
	<config name="minimum_wp_version" value="6.9"/>
</ruleset>
